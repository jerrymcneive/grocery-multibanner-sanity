{
  "name": "grocery-multibanner-sanity",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@grocery-multibanner/web",
    "dev:mobile": "turbo run dev --filter=@grocery-multibanner/mobile",
    "dev:mobile:ff": "turbo run dev --filter=@grocery-multibanner/mobile-festival-foods",
    "dev:mobile:hg": "turbo run dev --filter=@grocery-multibanner/mobile-hometown-grocers",
    "dev:sanity": "turbo run dev --filter=grocery-multibanner-sanity-studio",
    "build": "turbo run build",
    "build:mobile:ff": "turbo run build --filter=@grocery-multibanner/mobile-festival-foods",
    "build:mobile:hg": "turbo run build --filter=@grocery-multibanner/mobile-hometown-grocers",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "theme:verify": "node scripts/theme-verify.js"
  },
  "devDependencies": {
    "@sanity/client": "^6.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
